{
	"version": "2.0.0",
	"tasks": [
		// js/ts tasks
		{
			"label": "root: ts lint",
			"detail": "lint all js/ts apps & packages",
			"type": "shell",
			"command": "pnpm -r --no-bail --stream run lint",
			"problemMatcher": [],
		},
		{
			"label": "root: ts typecheck",
			"detail": "typecheck all js/ts apps & packages",
			"type": "npm",
			"script": "typecheck",
			"problemMatcher": [],
		},
		{
			"label": "root: cleanup node artifacts",
			"detail": "remove node_modules folders from all js/ts apps & packages",
			"type": "shell",
			"command": "find ./ -name node_modules -type d -exec rm -rf {} +",
		},

		// dotnet tasks
		{
			"label": "root: cleanup dotnet artifacts",
			"detail": "remove generated dotnet build artifacts",
			"type": "shell",
			"command": "find . -type d \\( -name bin -o -name obj \\) -exec rm -rf {} +",
		},
	]
}
