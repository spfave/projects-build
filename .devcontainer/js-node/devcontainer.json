// Refs:
// 	dev containers: https://code.visualstudio.com/docs/devcontainers/containers
//	dev container images: https://github.com/devcontainers/images
//	dev container features: https://github.com/devcontainers/features
//	format details: https://aka.ms/devcontainer.json
{
	"$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
	"name": "pb-js-local",

	// Image, Dockerfile, or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/base:ubuntu",
	// "image": "mcr.microsoft.com/devcontainers/javascript-node",

	// Features to add to the dev container. More info: https://containers.dev/features.
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {
			"configureZshAsDefaultShell": true
		},
		"ghcr.io/devcontainers/features/node:2": {
			"version": "latest",
			"pnpmVersion": "latest"
		},
	},

	// Workspace configuration
	"workspaceMount": "type=bind,source=${localWorkspaceFolder},target=/workspace/${localWorkspaceFolderBasename},consistency=cached",
	"workspaceFolder": "/workspace/${localWorkspaceFolderBasename}",
	"containerEnv": {
		"PNPM_HOME": "/home/vscode/.local/share/pnpm",
	},

	// Use 'mounts' to mount a local folder or file into the container. More info: https://containers.dev/guide/dockerfile#bind-mounts
	"mounts": [
		"type=volume,source=pnpm-store,target=/${containerEnv:PNPM_HOME}/store",
		// "type=volume, source=pb-persistence, target=${containerWorkspaceFolder}/persistence",
	],

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Use 'postCreateCommand' to run commands after the container is created.
	"postCreateCommand": ".devcontainer/js-node/post-create.sh",

	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": [
				"biomejs.biome",
				"humao.rest-client",
				"qwtel.sqlite-viewer",
				"streetsidesoftware.code-spell-checker",
				"tamasfe.even-better-toml",
				"YoavBls.pretty-ts-errors",
			],
		},
	},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
