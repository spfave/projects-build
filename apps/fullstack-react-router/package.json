{
	"name": "@projectsbuild/fullstack-react-router",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"start": "pnpm run run:local",
		"run:local": "dotenvx run -f ../../.env.local -- react-router dev",
		"build": "react-router build",
		"serve:build": "react-router-serve ./build/server/index.js",
		"check": "biome check ./app",
		"format": "biome format ./app",
		"lint": "biome lint ./app",
		"typecheck": "react-router typegen && tsc --noEmit"
	},
	"dependencies": {
		"@projectsbuild/core": "workspace:*",
		"@projectsbuild/db-drizzle": "workspace:*",
		"@projectsbuild/library": "workspace:*",
		"@react-router/node": "^7.13.1",
		"@react-router/serve": "^7.13.1",
		"isbot": "^5.1.35",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router": "^7.13.1"
	},
	"devDependencies": {
		"@dotenvx/dotenvx": "^1.52.0",
		"@projectsbuild/config-typescript": "workspace:*",
		"@react-router/dev": "^7.13.1",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "catalog:",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"tailwindcss": "^4.2.1",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vite-tsconfig-paths": "^6.1.1"
	}
}
